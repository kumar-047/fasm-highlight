{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "FASM",
  "scopeName": "source.fasm",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#sections" },
    { "include": "#labels" },
    { "include": "#directives" },
    { "include": "#keywords" },
    { "include": "#instructions" },
    { "include": "#registers" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#size-specifiers" },
    { "include": "#constants" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.semicolon.fasm",
          "match": ";.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.fasm",
          "begin": "\"",
          "end": "\""
        },
        {
          "name": "string.quoted.single.fasm",
          "begin": "'",
          "end": "'"
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "name": "entity.name.section.fasm",
          "match": "'\\.[A-Za-z0-9_]+'"
        }
      ]
    },
    "labels": {
      "patterns": [
        {
          "name": "entity.name.label.anonymous.fasm",
          "match": "^\\s*@@:"
        },
        {
          "name": "entity.name.label.local.fasm",
          "match": "^\\s*\\.[A-Za-z_][A-Za-z0-9_]*:"
        },
        {
          "name": "entity.name.label.fasm",
          "match": "^\\s*[A-Za-z_][A-Za-z0-9_]*:"
        },
        {
          "name": "keyword.control.label-reference.fasm",
          "match": "\\b(@[bf]|@[rf])\\b"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "storage.type.data.fasm",
          "match": "(?i)\\b(db|dw|dd|dq|dt|df|dp|du|rb|rw|rd|rq|rt|rf|rp|file)\\b"
        },
        {
          "name": "keyword.control.directive.structure.fasm",
          "match": "(?i)\\b(struc|ends|struct|union|common)\\b"
        },
        {
          "name": "keyword.control.directive.macro.fasm",
          "match": "(?i)\\b(macro|endm|local|purge|rept|irp|irpc|irps|irpv|match|forward|reverse|restore|postpone|restruc)\\b"
        },
        {
          "name": "keyword.control.directive.include.fasm",
          "match": "(?i)\\b(include)\\b"
        },
        {
          "name": "keyword.control.directive.constant.fasm",
          "match": "(?i)\\b(equ|fix|define)\\b"
        },
        {
          "name": "keyword.control.directive.format.fasm",
          "match": "(?i)\\b(format)\\b"
        },
        {
          "name": "keyword.control.directive.section.fasm",
          "match": "(?i)\\b(section|segment)\\b"
        },
        {
          "name": "keyword.control.directive.entry.fasm",
          "match": "(?i)\\b(entry)\\b"
        },
        {
          "name": "keyword.control.directive.addressing.fasm",
          "match": "(?i)\\b(use16|use32|use64)\\b"
        },
        {
          "name": "keyword.control.directive.conditional.fasm",
          "match": "(?i)\\b(if|else|elseif|endif|ifdef|ifndef|ifused|ifnused|ifid|ifnid|ifidn|ifnidn|while|break)\\b"
        },
        {
          "name": "keyword.control.directive.linkage.fasm",
          "match": "(?i)\\b(export|import|public|extrn|library)\\b"
        },
        {
          "name": "keyword.control.directive.other.fasm",
          "match": "(?i)\\b(align|virtual|end|display|org|load|store|times|repeat|label|while|assert|err|data)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "support.function.call-convention.fasm",
          "match": "(?i)\\b(invoke|stdcall|cinvoke|ccall|fastcall|proc|endp)\\b"
        },
        {
          "name": "support.function.builtin.fasm",
          "match": "(?i)\\b(sizeof|lengthof|length|size)\\b"
        }
      ]
    },
    "instructions": {
      "patterns": [
        {
          "name": "keyword.mnemonic.data-movement.fasm",
          "match": "(?i)\\b(mov|movs|movsx|movsxd|movzx|movd|movq|movdqa|movdqu|movaps|movups|movapd|movupd|movss|movsd|push|pop|pusha|pushad|popa|popad|pushf|pushfd|popf|popfd|pushw|pushd|popw|popd|pushfq|popfq|lea|les|lds|lfs|lgs|lss|xchg|xlat|xlatb|lahf|sahf|cwtl|cltd|cqto|cbw|cwd|cdq|cdqe|cqo|lodsb|lodsw|lodsd|lodsq|stosb|stosw|stosd|stosq|movsb|movsw|movsd|movsq|cmpsb|cmpsw|cmpsd|cmpsq|scasb|scasw|scasd|scasq|in|out|ins|outs|insb|insw|insd|outsb|outsw|outsd)\\b"
        },
        {
          "name": "keyword.mnemonic.arithmetic.fasm",
          "match": "(?i)\\b(add|adc|sub|sbb|mul|imul|div|idiv|inc|dec|neg|cmp|daa|das|aaa|aas|aam|aad|bswap|xadd|cmpxchg|cmpxchg8b|cmpxchg16b)\\b"
        },
        {
          "name": "keyword.mnemonic.logical.fasm",
          "match": "(?i)\\b(and|or|xor|not|test|shl|shr|sal|sar|rol|ror|rcl|rcr|shld|shrd|bt|bts|btr|btc|bsf|bsr|sete|setne|setg|setge|setl|setle|seta|setae|setb|setbe|sets|setns|seto|setno|setp|setnp|setpe|setpo|setz|setnz|setc|setnc)\\b"
        },
        {
          "name": "keyword.mnemonic.control-flow.fasm",
          "match": "(?i)\\b(jmp|je|jz|jne|jnz|jg|jnle|jge|jnl|jl|jnge|jle|jng|ja|jnbe|jae|jnb|jb|jnae|jbe|jna|jo|jno|js|jns|jp|jpe|jnp|jpo|jc|jnc|jcxz|jecxz|jrcxz|call|ret|retn|retf|iret|iretd|iretq|int|into|bound|enter|leave|loop|loope|loopz|loopne|loopnz|syscall|sysret|sysretq|sysenter|sysexit|sysexitq)\\b"
        },
        {
          "name": "keyword.mnemonic.string.fasm",
          "match": "(?i)\\b(rep|repe|repz|repne|repnz|scas|lods|stos|movs|cmps)\\b"
        },
        {
          "name": "keyword.mnemonic.flag.fasm",
          "match": "(?i)\\b(stc|clc|cmc|std|cld|sti|cli|lahf|sahf|pushf|pushfd|pushfq|popf|popfd|popfq)\\b"
        },
        {
          "name": "keyword.mnemonic.misc.fasm",
          "match": "(?i)\\b(nop|hlt|wait|lock|pause|cpuid|rdtsc|rdtscp|rdmsr|wrmsr|rdmsrq|wrmsrq|rdpmc|lfence|mfence|sfence|clflush|invlpg|invd|wbinvd|rsm|smsw|lmsw|lgdt|sgdt|lidt|sidt|lldt|sldt|ltr|str|lar|lsl|verr|verw|arpl|clts|swapgs|fxsave|fxrstor|fxsave64|fxrstor64)\\b"
        },
        {
          "name": "keyword.mnemonic.fpu.fasm",
          "match": "(?i)\\b(fld|fst|fstp|fild|fist|fistp|fbld|fbstp|fxch|fcmove|fcmovne|fcmovb|fcmovbe|fcmovnb|fcmovnbe|fcmovu|fcmovnu|fadd|faddp|fiadd|fsub|fsubp|fisub|fsubr|fsubrp|fisubr|fmul|fmulp|fimul|fdiv|fdivp|fidiv|fdivr|fdivrp|fidivr|fprem|fprem1|fabs|fchs|frndint|fscale|fsqrt|fxtract|fcom|fcomp|fcompp|fucom|fucomp|fucompp|ficom|ficomp|fcomi|fcomip|fucomi|fucomip|ftst|fxam|fsin|fcos|fsincos|fptan|fpatan|f2xm1|fyl2x|fyl2xp1|fldz|fld1|fldpi|fldl2e|fldl2t|fldlg2|fldln2|finit|fninit|fclex|fnclex|fstcw|fnstcw|fldcw|fstenv|fnstenv|fldenv|fsave|fnsave|frstor|fincstp|fdecstp|ffree|ffreep|fnop|fwait)\\b"
        },
        {
          "name": "keyword.mnemonic.mmx.fasm",
          "match": "(?i)\\b(movd|movq|packsswb|packssdw|packuswb|punpckhbw|punpckhwd|punpckhdq|punpcklbw|punpcklwd|punpckldq|paddb|paddw|paddd|paddsb|paddsw|paddusb|paddusw|psubb|psubw|psubd|psubsb|psubsw|psubusb|psubusw|pmullw|pmulhw|pmaddwd|pand|pandn|por|pxor|pcmpeqb|pcmpeqw|pcmpeqd|pcmpgtb|pcmpgtw|pcmpgtd|psllw|pslld|psllq|psrlw|psrld|psrlq|psraw|psrad|emms)\\b"
        },
        {
          "name": "keyword.mnemonic.sse.fasm",
          "match": "(?i)\\b(movaps|movups|movhps|movhlps|movlps|movlhps|movmskps|movss|addps|addss|subps|subss|mulps|mulss|divps|divss|rcpps|rcpss|sqrtps|sqrtss|rsqrtps|rsqrtss|maxps|maxss|minps|minss|cmpps|cmpss|comiss|ucomiss|andps|andnps|orps|xorps|shufps|unpckhps|unpcklps|cvtpi2ps|cvtps2pi|cvtsi2ss|cvtss2si|cvttps2pi|cvttss2si|ldmxcsr|stmxcsr|movapd|movupd|movhpd|movlpd|movmskpd|movsd|addpd|addsd|subpd|subsd|mulpd|mulsd|divpd|divsd|sqrtpd|sqrtsd|maxpd|maxsd|minpd|minsd|cmppd|cmpsd|comisd|ucomisd|andpd|andnpd|orpd|xorpd|shufpd|unpckhpd|unpcklpd|cvtpd2pi|cvtpi2pd|cvtpd2dq|cvtdq2pd|cvtps2pd|cvtpd2ps|cvtss2sd|cvtsd2ss|cvtdq2ps|cvtps2dq|cvttps2dq|cvttpd2pi|cvttpd2dq|movdqa|movdqu|movdq2q|movq2dq|pmuludq|paddq|psubq|pshuflw|pshufhw|pshufd|pslldq|psrldq|punpckhqdq|punpcklqdq|clflush|lfence|mfence|pause|maskmovdqu|movntdq|movntpd|movntps|movnti|pinsrw|pextrw|pmovmskb|pmaxub|pmaxsw|pminub|pminsw|pavgb|pavgw|psadbw|roundps|roundss|roundpd|roundsd|dpps|dppd|mpsadbw|blendps|blendvps|blendpd|blendvpd|pblendw|pblendvb|insertps|extractps|pinsrb|pinsrd|pinsrq|pextrb|pextrd|pextrq|pmulld|pmuldq|pminsb|pmaxsb|pminuw|pmaxuw|pminud|pmaxud|pminsd|pmaxsd|ptest|pcmpeqq|packusdw|phminposuw|pcmpestri|pcmpestrm|pcmpistri|pcmpistrm|crc32|popcnt|lzcnt|tzcnt|movntdqa|pmovsxbw|pmovsxbd|pmovsxbq|pmovsxwd|pmovsxwq|pmovsxdq|pmovzxbw|pmovzxbd|pmovzxbq|pmovzxwd|pmovzxwq|pmovzxdq)\\b"
        },
        {
          "name": "keyword.mnemonic.avx.fasm",
          "match": "(?i)\\b(vaddpd|vaddps|vaddsd|vaddss|vaddsubpd|vaddsubps|vaesdec|vaesdeclast|vaesenc|vaesenclast|vaesimc|vaeskeygenassist|vandnpd|vandnps|vandpd|vandps|vblendpd|vblendps|vblendvpd|vblendvps|vbroadcastf128|vbroadcastsd|vbroadcastss|vcmppd|vcmpps|vcmpsd|vcmpss|vcomisd|vcomiss|vcvtdq2pd|vcvtdq2ps|vcvtpd2dq|vcvtpd2ps|vcvtps2dq|vcvtps2pd|vcvtsd2si|vcvtsd2ss|vcvtsi2sd|vcvtsi2ss|vcvtss2sd|vcvtss2si|vcvttpd2dq|vcvttps2dq|vcvttsd2si|vcvttss2si|vdivpd|vdivps|vdivsd|vdivss|vdppd|vdpps|vextractf128|vextractps|vhaddpd|vhaddps|vhsubpd|vhsubps|vinsertf128|vinsertps|vlddqu|vldmxcsr|vmaskmovdqu|vmaskmovpd|vmaskmovps|vmaxpd|vmaxps|vmaxsd|vmaxss|vminpd|vminps|vminsd|vminss|vmovapd|vmovaps|vmovd|vmovddup|vmovdqa|vmovdqu|vmovhlps|vmovhpd|vmovhps|vmovlhps|vmovlpd|vmovlps|vmovmskpd|vmovmskps|vmovntdq|vmovntdqa|vmovntpd|vmovntps|vmovq|vmovsd|vmovshdup|vmovsldup|vmovss|vmovupd|vmovups|vmpsadbw|vmulpd|vmulps|vmulsd|vmulss|vorpd|vorps|vpabsb|vpabsd|vpabsw|vpackssdw|vpacksswb|vpackusdw|vpackuswb|vpaddb|vpaddd|vpaddq|vpaddsb|vpaddsw|vpaddusb|vpaddusw|vpaddw|vpalignr|vpand|vpandn|vpavgb|vpavgw|vpblendvb|vpblendw|vpclmulqdq|vpcmpeqb|vpcmpeqd|vpcmpeqq|vpcmpeqw|vpcmpestri|vpcmpestrm|vpcmpgtb|vpcmpgtd|vpcmpgtq|vpcmpgtw|vpcmpistri|vpcmpistrm|vperm2f128|vpermilpd|vpermilps|vpextrb|vpextrd|vpextrq|vpextrw|vphaddd|vphaddsw|vphaddw|vphminposuw|vphsubd|vphsubsw|vphsubw|vpinsrb|vpinsrd|vpinsrq|vpinsrw|vpmaddubsw|vpmaddwd|vpmaxsb|vpmaxsd|vpmaxsw|vpmaxub|vpmaxud|vpmaxuw|vpminsb|vpminsw|vpminsd|vpminub|vpminud|vpminuw|vpmovmskb|vpmovsxbd|vpmovsxbq|vpmovsxbw|vpmovsxdq|vpmovsxwd|vpmovsxwq|vpmovzxbd|vpmovzxbq|vpmovzxbw|vpmovzxdq|vpmovzxwd|vpmovzxwq|vpmuldq|vpmulhrsw|vpmulhuw|vpmulhw|vpmulld|vpmullw|vpmuludq|vpor|vpsadbw|vpshufb|vpshufd|vpshufhw|vpshuflw|vpsignb|vpsignd|vpsignw|vpslld|vpslldq|vpsllq|vpsllw|vpsrad|vpsraw|vpsrld|vpsrldq|vpsrlq|vpsrlw|vpsubb|vpsubd|vpsubq|vpsubsb|vpsubsw|vpsubusb|vpsubusw|vpsubw|vptest|vpunpckhbw|vpunpckhdq|vpunpckhqdq|vpunpckhwd|vpunpcklbw|vpunpckldq|vpunpcklqdq|vpunpcklwd|vpxor|vrcpps|vrcpss|vroundpd|vroundps|vroundsd|vroundss|vrsqrtps|vrsqrtss|vshufpd|vshufps|vsqrtpd|vsqrtps|vsqrtsd|vsqrtss|vstmxcsr|vsubpd|vsubps|vsubsd|vsubss|vtestpd|vtestps|vucomisd|vucomiss|vunpckhpd|vunpckhps|vunpcklpd|vunpcklps|vxorpd|vxorps|vzeroall|vzeroupper)\\b"
        }
      ]
    },
    "registers": {
      "patterns": [
        {
          "name": "variable.language.register.general.64bit.fasm",
          "match": "(?i)\\b(rax|rbx|rcx|rdx|rsi|rdi|rbp|rsp|r8|r9|r10|r11|r12|r13|r14|r15)\\b"
        },
        {
          "name": "variable.language.register.general.32bit.fasm",
          "match": "(?i)\\b(eax|ebx|ecx|edx|esi|edi|ebp|esp|r8d|r9d|r10d|r11d|r12d|r13d|r14d|r15d)\\b"
        },
        {
          "name": "variable.language.register.general.16bit.fasm",
          "match": "(?i)\\b(ax|bx|cx|dx|si|di|bp|sp|r8w|r9w|r10w|r11w|r12w|r13w|r14w|r15w)\\b"
        },
        {
          "name": "variable.language.register.general.8bit.fasm",
          "match": "(?i)\\b(al|bl|cl|dl|ah|bh|ch|dh|sil|dil|bpl|spl|r8b|r9b|r10b|r11b|r12b|r13b|r14b|r15b)\\b"
        },
        {
          "name": "variable.language.register.segment.fasm",
          "match": "(?i)\\b(cs|ds|es|fs|gs|ss)\\b"
        },
        {
          "name": "variable.language.register.control.fasm",
          "match": "(?i)\\b(cr0|cr1|cr2|cr3|cr4|cr5|cr6|cr7|cr8)\\b"
        },
        {
          "name": "variable.language.register.debug.fasm",
          "match": "(?i)\\b(dr0|dr1|dr2|dr3|dr4|dr5|dr6|dr7)\\b"
        },
        {
          "name": "variable.language.register.fpu.fasm",
          "match": "(?i)\\b(st|st0|st1|st2|st3|st4|st5|st6|st7)\\b"
        },
        {
          "name": "variable.language.register.mmx.fasm",
          "match": "(?i)\\b(mm0|mm1|mm2|mm3|mm4|mm5|mm6|mm7)\\b"
        },
        {
          "name": "variable.language.register.xmm.fasm",
          "match": "(?i)\\b(xmm0|xmm1|xmm2|xmm3|xmm4|xmm5|xmm6|xmm7|xmm8|xmm9|xmm10|xmm11|xmm12|xmm13|xmm14|xmm15)\\b"
        },
        {
          "name": "variable.language.register.ymm.fasm",
          "match": "(?i)\\b(ymm0|ymm1|ymm2|ymm3|ymm4|ymm5|ymm6|ymm7|ymm8|ymm9|ymm10|ymm11|ymm12|ymm13|ymm14|ymm15)\\b"
        },
        {
          "name": "variable.language.register.zmm.fasm",
          "match": "(?i)\\b(zmm0|zmm1|zmm2|zmm3|zmm4|zmm5|zmm6|zmm7|zmm8|zmm9|zmm10|zmm11|zmm12|zmm13|zmm14|zmm15|zmm16|zmm17|zmm18|zmm19|zmm20|zmm21|zmm22|zmm23|zmm24|zmm25|zmm26|zmm27|zmm28|zmm29|zmm30|zmm31)\\b"
        },
        {
          "name": "variable.language.register.opmask.fasm",
          "match": "(?i)\\b(k0|k1|k2|k3|k4|k5|k6|k7)\\b"
        },
        {
          "name": "variable.language.register.bounds.fasm",
          "match": "(?i)\\b(bnd0|bnd1|bnd2|bnd3)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.fasm",
          "match": "\\b(0x[0-9a-fA-F]+|[0-9][0-9a-fA-F]*h)\\b"
        },
        {
          "name": "constant.numeric.binary.fasm",
          "match": "\\b(0b[01]+|[01]+b)\\b"
        },
        {
          "name": "constant.numeric.octal.fasm",
          "match": "\\b(0o[0-7]+|[0-7]+o)\\b"
        },
        {
          "name": "constant.numeric.decimal.fasm",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.special.fasm",
          "match": "(\\$|#|`|%)"
        },
        {
          "name": "keyword.operator.word.fasm",
          "match": "(?i)\\b(offset|ptr|and|or|xor|not|shl|shr|mod|dup|short|near|far|rva|plt)\\b"
        },
        {
          "name": "keyword.operator.arithmetic.fasm",
          "match": "(\\+|\\-|\\*|\\/)"
        }
      ]
    },
    "size-specifiers": {
      "patterns": [
        {
          "name": "storage.type.size.fasm",
          "match": "(?i)\\b(byte|word|dword|fword|pword|qword|tbyte|tword|dqword|xword|qqword|yword|dqqword|zword)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "variable.other.constant.fasm",
          "match": "\\b[A-Z_][A-Z0-9_]*\\b"
        }
      ]
    }
  }
}
